# ตัวอย่างการตั้งค่า Google login (OIDC) — คัดลอกเป็น secrets.toml แล้วกรอกค่าจริง
# ห้าม commit secrets.toml ลง git (ถูกกันไว้ใน .gitignore แล้ว)
#
# ขั้นตอนขอ credentials:
# 1. https://console.cloud.google.com → APIs & Services → Credentials
# 2. Create OAuth client ID (Web application)
# 3. Authorized redirect URI:
#    - โลคัล:  http://localhost:8501/oauth2callback
#    - Cloud:  https://<your-app>.streamlit.app/oauth2callback
# 4. บน Streamlit Community Cloud ให้วางเนื้อหานี้ใน App settings → Secrets

[auth]
redirect_uri = "http://localhost:8501/oauth2callback"
cookie_secret = "REPLACE-WITH-LONG-RANDOM-STRING"
client_id = "xxxx.apps.googleusercontent.com"
client_secret = "GOCSPX-xxxx"
server_metadata_url = "https://accounts.google.com/.well-known/openid-configuration"
